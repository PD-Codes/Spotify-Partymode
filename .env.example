# Spotify-Partymode no longer needs a .env for normal use.
# All configuration (Spotify credentials, playlist, session secret, poll
# interval) is stored in the database and set up via the in-app setup wizard
# on first launch.
#
# This file only holds optional *bootstrap* overrides, mainly useful for Docker.
# Copy to ".env" if you need to change any of these.

# SQLite database file location.
# DATABASE_PATH=partymode.db

# Web server bind address.
# HOST=0.0.0.0
# PORT=8000
